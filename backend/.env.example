# ---------------------------------------------------------------------------
# Resume Parser API — environment configuration example
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# Path to the Tesseract executable (only needed if Tesseract is not on PATH).
# Windows example:  TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/macOS:      TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_CMD=

# Directory containing Tesseract language data files (optional).
# Usually auto-detected; set this if you see "tessdata" not found errors.
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata
TESSDATA_PREFIX=
